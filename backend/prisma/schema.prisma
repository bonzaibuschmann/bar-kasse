generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  order    Int       @default(0)
  products Product[]
}

model Product {
  id                Int       @id @default(autoincrement())
  name              String
  price             Float
  volume            Float?
  categoryId        Int
  category          Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isDeposit         Boolean   @default(false)
  active            Boolean   @default(true)
  display           Boolean   @default(true)
  order             Int       @default(0)
  color             String?
  image             String?
  depositId         Int?
  deposit           Product?  @relation("ProductDeposit", fields: [depositId], references: [id], onDelete: SetNull)
  depositFor        Product[]      @relation("ProductDeposit")
  defaultContainerId Int?
  defaultContainer   Container? @relation(fields: [defaultContainerId], references: [id], onDelete: SetNull)
  gridLayout        GridLayout?
  orderItems        OrderItem[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Container {
  id              Int          @id @default(autoincrement())
  name            String
  deposit         Float        @default(0)
  image           String?
  inboundColor    String?
  inboundIcon     String?
  outboundColor   String?
  outboundIcon    String?
  products        Product[]
  gridLayouts     GridLayout[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Order {
  id           Int            @id @default(autoincrement())
  total        Float
  cashGiven    Float?
  changeDue    Float?
  registerId   Int?
  register     Register?      @relation(fields: [registerId], references: [id], onDelete: SetNull)
  note         String?
  customerType String         @default("Guest")
  createdAt    DateTime       @default(now())
  items        OrderItem[]
  revisions    OrderRevision[]
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  orderId    Int
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int     @default(1)
  unitPrice  Float
  isDeposit  Boolean @default(false)
  depositFor Int?    // links this deposit item to the parent order item
}

model OrderRevision {
  id           Int      @id @default(autoincrement())
  orderId      Int
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  total        Float
  cashGiven    Float?
  changeDue    Float?
  note         String?
  customerType String
  items        String   // JSON snapshot of previous OrderItems
  createdAt    DateTime @default(now())
}

model Register {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
}

model StaffGroup {
  id       Int           @id @default(autoincrement())
  name     String
  order    Int           @default(0)
  members  StaffMember[]
}

model StaffMember {
  id       Int        @id @default(autoincrement())
  name     String
  order    Int        @default(0)
  group    StaffGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId  Int
}

model GridLayout {
  id          Int        @id @default(autoincrement())
  itemType    String     @default("Product") // "Product" | "InboundContainer" | "OutboundContainer" | "Special"
  productId   Int?       @unique
  product     Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  containerId Int?
  container   Container? @relation(fields: [containerId], references: [id], onDelete: SetNull)
  xPosition   Int        @default(0)
  yPosition   Int        @default(0)
  width       Int        @default(1)
  height      Int        @default(1)
}

model SpecialBox {
  id        Int      @id @default(autoincrement())
  name      String   @default("Special")
  price     Float    @default(5)
  color     String?  @default("#b45309")
  icon      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
